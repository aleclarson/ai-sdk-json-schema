{
  "name": "ai-sdk-json-schema",
  "version": "0.1.0",
  "license": "MIT",
  "author": "Alec Larson",
  "repository": {
    "type": "git",
    "url": "https://github.com/aleclarson/ai-sdk-json-schema.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./schemas/*": "./dist/schemas/*"
  },
  "scripts": {
    "dev": "tsdown --sourcemap --watch",
    "build": "tsdown && bun scripts/emit-json-schema-files.ts",
    "generate": "bun scripts/generate.ts --since 2025-10-01",
    "format": "oxfmt .",
    "lint": "oxlint src",
    "typecheck": "tsc --noEmit && tsc -p test --noEmit && tsc -p examples --noEmit",
    "test": "bun test",
    "prepare": "pnpm build"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@ai-sdk/openai": "^3.0.52",
    "@ai-sdk/openai-compatible": "^2.0.41",
    "@openrouter/ai-sdk-provider": "^2.5.1",
    "@types/bun": "^1.3.12",
    "@types/node": "^25.6.0",
    "ai-gateway-provider": "^3.1.3",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "tsdown": "^0.21.7",
    "tsnapi": "^0.1.1",
    "typescript": "^6.0.2"
  }
}
